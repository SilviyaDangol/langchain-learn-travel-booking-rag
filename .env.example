# Copy to .env and fill in real values (never commit .env)

# OpenAI
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini

# Optional LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Pinecone
PINECONE_DEFAULT_API=
PINECONE_INDEX_NAME=
PINECONE_DESTINATIONS_NAMESPACE=holiday-destinations

# PostgreSQL (match your docker-compose or local Postgres)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/lang-learn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=lang-learn 
